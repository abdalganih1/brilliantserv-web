# Brilliant Serv - SEO Recovery Redirects
# Arabic URL Rewrites for GSC indexed pages
# Created: February 1, 2026

RewriteEngine On
RewriteBase /

# =====================================================
# Service Detail Pages - Clean URLs
# =====================================================
RewriteRule ^services/([a-z0-9-]+)/?$ service-detail.php?service=$1 [L,QSA]

# =====================================================
# Custom Error Pages
# =====================================================
ErrorDocument 403 /403.php
ErrorDocument 404 /404.php
ErrorDocument 410 /410.php

# =====================================================
# Legacy WordPress URLs - Return 410 Gone
# Tells Google to stop crawling and remove from index
# =====================================================
RewriteRule ^tag/.* - [G,L]
RewriteRule ^category/.* - [G,L]
RewriteRule ^.*/feed/?$ - [G,L]
RewriteRule ^wp-content/.* - [G,L]
RewriteRule ^wp-includes/.* - [G,L]

# =====================================================
# FIX: Nested Blog URLs (e.g., /service-page/blog/article.php)
# This fixes ~80 pages of 404 errors from GSC, but excludes media/
# =====================================================
RewriteCond %{REQUEST_URI} !^/media/
RewriteRule ^[^/]+/blog/(.+)$ /blog/$1 [R=301,L]

# =====================================================
# Missing Service Page Redirects (GSC 404 fixes)
# =====================================================

# VFD Drive Repair (new article)
RewriteRule ^إصلاح-وصيانة-كروت-الرفودرايف/?$ /blog/vfd-drive-repair.php [R=301,L]

# Electrical Works Company
RewriteRule ^مؤسسة-تنفيذ-أعمال-كهرباء/?$ /blog/electrical-layouts-for-buildings.php [R=301,L]

# PLC Programming
RewriteRule ^خبراء-في-برمجة-plc/?$ /blog/plc-control-panels.php [R=301,L]

# Pump Maintenance (general)
RewriteRule ^صيانة-مضخات-المياه-الاحترافية/?$ /blog/pump-repair-north-riyadh.php [R=301,L]

# Panel Manufacturing
RewriteRule ^تصنيع-لوحات-التوزيع-الكهربائية/?$ /blog/star-delta-panel-manufacturing.php [R=301,L]

# MDB Panel Supply
RewriteRule ^تصنيع-وتوريد-لوحات-mdb/?$ /blog/control-panel-prices-2026.php [R=301,L]

# Best Electrical Contractor
RewriteRule ^افضل-مقاول-كهرباء/?$ /blog/electrical-contractor-best.php [R=301,L]

# About / Contact without extension
RewriteRule ^about/?$ /about.html [R=301,L]
RewriteRule ^contact-us/?$ /contact.html [R=301,L]
RewriteRule ^contact/?$ /contact.html [R=301,L]

# 301 Redirect - Old URL to new canonical page
RewriteRule ^لف-مواتير-ومحولات/?$ /لف-المحركات-الكهربائية/ [R=301,L]

# =====================================================
# Arabic Service Pages → Blog Articles (Internal Rewrite)
# =====================================================

# لف المحركات الكهربائية
RewriteRule ^لف-المحركات-الكهربائية/?$ blog/لف-المحركات-الكهربائية.php [L,NC]

# صيانة البوردات الالكترونية - ARCHIVED (410 Gone)
RewriteRule ^صيانة-البوردات-الالكترونية/?$ - [G,L]

# صيانة الكروت الإلكترونية - ARCHIVED (410 Gone)
RewriteRule ^صيانة-الكروت-الإلكترونية/?$ - [G,L]

# صيانة مضخات جراندفوس
RewriteRule ^صيانة-مضخات-جراندفوس/?$ blog/صيانة-مضخات-جراندفوس.php [L,NC]

# إصلاح وصيانة انفرتر - ARCHIVED (410 Gone)
RewriteRule ^إصلاح-وصيانة-انفرتر/?$ - [G,L]

# المخططات الكهربائية للمباني
RewriteRule ^المخططات-الكهربائية-للمباني/?$ blog/المخططات-الكهربائية-للمباني.php [L,NC]

# سرعة المحركات الكهربائية
RewriteRule ^سرعة-المحركات-الكهربائية/?$ blog/سرعة-المحركات-الكهربائية.php [L,NC]

# تجميع لوحات التحكم
RewriteRule ^تجميع-لوحات-التحكم/?$ blog/تجميع-لوحات-التحكم.php [L,NC]

# لوحات التحكم الكهربائية - الدليل الشامل
RewriteRule ^لوحات-التحكم-الكهربائية/?$ blog/لوحات-التحكم-الكهربائية.php [L,NC]

# انواع المضخات
RewriteRule ^انواع-المضخات/?$ blog/انواع-المضخات.php [L,NC]

# =====================================================
# New Hydraulic Maintenance Articles - Phase 3 (Feb 2026)
# =====================================================

# صيانة مضخات الهيدروليك
RewriteRule ^صيانة-مضخات-الهيدروليك/?$ blog/صيانة-مضخات-الهيدروليك.php [L,NC]

# صيانة بلوف الهيدروليك
RewriteRule ^صيانة-بلوف-الهيدروليك/?$ blog/صيانة-بلوف-الهيدروليك.php [L,NC]

# صيانة بساتم الهيدروليك
RewriteRule ^صيانة-بساتم-الهيدروليك/?$ blog/صيانة-بساتم-الهيدروليك.php [L,NC]

# دور الكهرباء الصناعية في تطوير المصانع
RewriteRule ^دور-الكهرباء-الصناعية-في-تطوير-المصان/?$ blog/دور-الكهرباء-الصناعية-في-تطوير-المصان.php [L,NC]

# =====================================================
# Clean URLs - Serve blog posts without .php extension
# =====================================================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/blog/$1.php -f
RewriteRule ^blog/([^/]+)/?$ /blog/$1.php [L]

# =====================================================
# Additional Redirects - Keep old English URLs working
# =====================================================

# Redirect old HTML to new PHP
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^blog/(.+)\.html$ blog/$1.php [L,R=301]


# =====================================================
# Force Download for /downloads/ folder (PDF files)
# =====================================================
<IfModule mod_headers.c>
    <FilesMatch "downloads/.*\.pdf$">
        Header set Content-Disposition "attachment"
    </FilesMatch>
</IfModule>

# =====================================================
# General Settings
# =====================================================

# Enable compression
<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json
</IfModule>

# Force UTF-8 encoding for text files (Arabic support)
AddDefaultCharset UTF-8
<FilesMatch "\.(txt|md|json)$">
    AddCharset UTF-8 .txt .md .json
</FilesMatch>

# Cache static assets
<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType image/webp "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 year"
ExpiresByType image/png "access plus 1 year"
ExpiresByType text/css "access plus 1 month"
ExpiresByType application/javascript "access plus 1 month"
</IfModule>
